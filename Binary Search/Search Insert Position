class Solution {
public:
    int searchInsert(vector<int>& nums, int target) 
    {
        int n=nums.size();
        int l=0,r=n-1;

        while(l<=r)
        {
            int mid=(r-l)/2+l;
            if(target==nums[mid]) return mid;

            if(nums[mid]>target) r=mid-1;
            else l=mid+1;
        }
        return l;
    }
};
